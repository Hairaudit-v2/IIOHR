# Supabase (required for /doctors/pilot-academy persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical origin for magic-link redirects (must match an entry in Supabase Auth → Redirect URLs)
# e.g. http://localhost:3000 or https://iiohr.com
NEXT_PUBLIC_SITE_URL=

# Optional: Resend (https://resend.com) for academy admissions emails. If unset, notifications are skipped safely.
# RESEND_API_KEY=
# Verified sender in Resend, e.g. "IIOHR Academy <admissions@yourdomain.com>"
# ADMISSIONS_EMAIL_FROM=
# Set to "true" to email applicants when status moves to under_review (off by default to reduce noise).
# ADMISSIONS_NOTIFY_UNDER_REVIEW=
