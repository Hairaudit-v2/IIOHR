{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iiohr.com/schemas/academy/admin-workflow.schema.json",
  "title": "AcademyAdminWorkflowProposal",
  "type": "object",
  "additionalProperties": false,
  "required": ["statuses", "stages"],
  "properties": {
    "statuses": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["draft", "review", "approved", "published", "archived"]
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "ownerRole", "action"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "ownerRole": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    }
  }
}
