{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://iiohr.com/schemas/academy/compliance-notice.schema.json",
  "title": "ComplianceNotice",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "programId",
    "noticeType",
    "title",
    "body",
    "severity",
    "appliesTo",
    "displayMode"
  ],
  "properties": {
    "id": { "type": "string" },
    "programId": { "type": "string" },
    "noticeType": { "type": "string" },
    "title": { "type": "string" },
    "body": { "type": "string" },
    "severity": { "type": "string", "enum": ["info", "caution", "critical"] },
    "appliesTo": { "type": "array", "items": { "type": "string" } },
    "displayMode": { "type": "string", "enum": ["inline", "banner", "modal", "sidebar"] }
  }
}
